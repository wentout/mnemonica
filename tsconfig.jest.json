{
	"compilerOptions": {
		"module": "commonjs",
		"target": "es6",
		"strict": true,
		"alwaysStrict": true,

		"declaration": false,
		"diagnostics": true,

		"noImplicitAny": true,
		"strictNullChecks": true,
		"strictFunctionTypes": false,
		"noImplicitThis": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"noImplicitReturns": false,
		"noFallthroughCasesInSwitch": false,

		"extendedDiagnostics": true,
		"forceConsistentCasingInFileNames": true,
		"removeComments": true,
		"traceResolution": false,
		"types": [
			"jest",
			"node"
		]
	},
	"include": [
		"./src/**/*.ts",
		"./test-jest/**/*"
	]
}
