{
  "name": "mnemonica",
  "version": "1.0.8",
  "description": "AI-agent ready instance inheritance system for JavaScript/TypeScript via prototype chains",
  "type": "commonjs",
  "main": "./build/index.js",
  "types": "./build/index.d.ts",
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "default": "./build/index.js"
    },
    "./module": {
      "types": "./build/index.d.ts",
      "import": "./module/index.js",
      "browser": "./module/index.js",
      "require": "./build/index.js",
      "default": "./build/index.js"
    }
  },
  "files": [
    "README.md",
    "FOR_HUMANS.md",
    "LICENSE",
    "AGENTS.md",
    "SKILL.md",
    "CONTRIBUTING.md",
    ".ai",
    "docs",
    "src",
    "module",
    "build"
  ],
  "directories": {
    "build": "build/",
    "module": "module/"
  },
  "contributors": [
    "laplandin <laplandin.denis@gmail.com>",
    "petrgrishin <iam@petrgrishin.com>",
    "Mobydack <devzetsubou@gmail.com>"
  ],
  "scripts": {
    "build": "rm -rf ./build && npx tsc --pretty --project tsconfig.json",
    "build:all": "npm run build && npm run decorate:ts",
    "verify": "npm run build && npm run lint:check",
    "example": "npm run build && node ./test/example.js",
    "example:async": "npm run build && node ./examples/AsyncNewTest.js",
    "example:rename": "npm run build && node ./examples/ClassReName.js",
    "example:v8bug": "npm run build && node ./examples/v8bug.js",
    "example:ts": "npx tsc ./test-ts/*.ts && npx eslint --fix ./test-ts/*.js && node ./test-ts/test-no-types.js && node ./test-ts/test-with-types.js",
    "deopt": "node --trace-deopt --trace-opt ./node_modules/mocha/bin/mocha.js ./test/index.js",
    "decorate:ts": "npx tsc --ignoreConfig --target ES2021 --moduleResolution NodeNext --module NodeNext --sourceMap ./test/decorate.ts",
    "lint:md": "find . -name '*.md' -not -path '*/node_modules/*' | xargs markdown-link-check -q --config .markdown-link-check.json",
    "lint": "npx eslint",
    "lint:check": "npx eslint ./src ./test",
    "lint:src": "npx eslint --fix ./src",
    "lint:test": "npx eslint --fix ./test",
    "lint:fix": "npm run lint:src && npm run lint:test",
    "pretest": "npm run decorate:ts",
    "test": "mocha --allow-uncaught --enable-source-maps test/index.js",
    "test:cov": "npm run build:all && nyc --reporter=text-summary --reporter=lcov mocha --allow-uncaught --enable-source-maps --ui bdd --reporter spec ./test/index.js",
    "debug": "npx tsc --pretty --project tsconfig.json && npx mocha --allow-uncaught --enable-source-maps --reporter spec --inspect-brk test/index",
    "test:jest": "npx jest",
    "test:async_init": "mocha --allow-uncaught test_async/index.js",
    "test:jest:cov": "npx jest --collectCoverage",
    "test:jest:debug": "npx --node-options=--inspect-brk jest",
    "test:mjs": "npm run build && node --experimental-modules ./test/test.mjs",
    "watch": "npx tsc --pretty --project tsconfig.json -w",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wentout/mnemonica.git"
  },
  "keywords": [
    "ETL",
    "DFD",
    "inheritance",
    "instance-inheritance",
    "prototype-inheritance",
    "prototype-chain",
    "typescript",
    "nodejs",
    "decorator",
    "data-flow",
    "mnemonica",
    "ai-agents",
    "agent-ready"
  ],
  "author": "went.out@gmail.com",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/wentout/mnemonica/issues"
  },
  "homepage": "https://github.com/wentout/mnemonica#readme",
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.21.0",
    "@mnemonica/tactica": "^0.1.2",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.19.21",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "chai": "^5.3.3",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-mocha": "^10.5.0",
    "eslint-plugin-no-arrow-this": "^1.2.0",
    "globals": "^15.15.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "json5": "^2.2.3",
    "lint-staged": "^15.5.2",
    "markdown-link-check": "^3.14.2",
    "mocha": "^11.7.6",
    "mocha-lcov-reporter": "^1.3.0",
    "nyc": "^17.1.0",
    "oxlint": "^0.16.12",
    "ts-jest": "^29.4.11",
    "typeomatica": "^0.3.57",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=18 <26"
  },
  "overrides": {
    "serialize-javascript": "^7.0.5",
    "uuid": "^11.1.1",
    "diff": "^9.0.0"
  },
  "lint-staged": {
    "src/**/*.ts": "eslint --fix",
    "test/**/*.js": "eslint --fix"
  }
}
